# Anthropic API key (required). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model for all sessions (always Haiku unless you set a Haiku-specific id here)
# Default in code: claude-haiku-4-5
# ANTHROPIC_MODEL=claude-haiku-4-5

# Coach voice (Microsoft Edge neural TTS, free — no API key)
# Default: en-US-AndrewMultilingualNeural
# Other options: en-US-AvaMultilingualNeural, en-US-JennyNeural, en-US-GuyNeural
# TTS_VOICE=en-US-AndrewMultilingualNeural
